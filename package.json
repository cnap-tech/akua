{
	"name": "akua-workspace",
	"version": "0.0.0",
	"private": true,
	"description": "Akua monorepo root — cloud-native package build and transform toolkit",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/cnap-tech/akua"
	},
	"workspaces": [
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"build": "bun run --filter '*' build",
		"test": "bun run --filter '*' test",
		"lint": "bun run --filter '*' lint",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"prettier": "^3.3.0",
		"typescript": "^5.6.0"
	},
	"engines": {
		"bun": ">=1.3"
	}
}
