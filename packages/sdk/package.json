{
  "name": "@akua-dev/sdk",
  "version": "0.8.3",
  "description": "TypeScript SDK for akua — render Kubernetes Packages in-process. Helm + Kustomize engines, OCI fetch, cosign verify, JSON Schema export. No `akua` binary required.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cnap-tech/akua.git"
  },
  "homepage": "https://github.com/cnap-tech/akua#readme",
  "type": "module",
  "main": "./dist/mod.js",
  "types": "./dist/mod.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "default": "./dist/mod.js"
    }
  },
  "files": [
    "dist",
    "src/schemas/akua.json",
    "README.md"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "scripts": {
    "build": "bun build src/mod.ts --target node --format esm --outdir dist --sourcemap=linked && bunx tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@akua-dev/native": "0.8.3",
    "@standard-schema/spec": "^1.1.0",
    "ajv": "^8.18.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tar": "^7.5.13",
    "typescript": "^5.6.0"
  }
}
