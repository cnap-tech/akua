{
  "$defs": {
    "AgentContext": {
      "description": "Result of agent-context detection at process start.\n\nWhen `detected == true`, the CLI layer should (per §1.5) auto-enable\n`--json`, `--log=json`, `--no-color`, `--no-progress`, `--no-interactive`.\nExplicit user flags win over these defaults.",
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "disabled_via_env": {
          "description": "Whether detection was disabled via `AKUA_NO_AGENT_DETECT=1`.",
          "type": "boolean"
        },
        "name": {
          "description": "The value of the detected env var (e.g. `\"goose\"` for `AGENT=goose`).\nFor bool-style markers (`CLAUDECODE=1`) this is the raw string.",
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "anyOf": [
            {
              "$ref": "#/$defs/AgentSource"
            },
            {
              "type": "null"
            }
          ],
          "description": "Which env var surfaced the agent (present iff `detected`)."
        }
      },
      "required": [
        "detected",
        "disabled_via_env"
      ],
      "type": "object"
    },
    "AgentSource": {
      "description": "Which env var triggered agent detection. Recorded in `akua whoami`\noutput for introspection and in debug-level logs for post-hoc diagnosis.",
      "oneOf": [
        {
          "const": "agent",
          "description": "Generic `AGENT=<name>` variable (Goose, Amp, Codex, Cline, OpenCode).",
          "type": "string"
        },
        {
          "const": "claude_code",
          "description": "Claude Code (`CLAUDECODE=1`).",
          "type": "string"
        },
        {
          "const": "gemini_cli",
          "description": "Gemini CLI (`GEMINI_CLI=1`).",
          "type": "string"
        },
        {
          "const": "cursor_cli",
          "description": "Cursor CLI (`CURSOR_CLI=1`).",
          "type": "string"
        },
        {
          "const": "akua_agent",
          "description": "akua-specific fallback (`AKUA_AGENT=<name>`).",
          "type": "string"
        }
      ]
    },
    "CheckOutput": {
      "description": "Output shape for `akua check --json`. The `status` field is\n`\"ok\"` iff every entry in `checks` has `ok == true`.",
      "properties": {
        "checks": {
          "items": {
            "$ref": "#/$defs/CheckResult"
          },
          "type": "array"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "status",
        "checks"
      ],
      "type": "object"
    },
    "CheckResult": {
      "description": "One structural gate's verdict. `name` is the gate label:\n`\"manifest\"`, `\"lockfile\"`, `\"package\"`.",
      "properties": {
        "error": {
          "description": "One-line error from the failing check. `#[serde(default)]` is\nload-bearing — schemars uses it to mark the field optional.",
          "type": [
            "string",
            "null"
          ]
        },
        "issues": {
          "description": "Per-file KCL lint issues — only the `\"package\"` check\npopulates this; the other gates leave it empty.",
          "items": {
            "$ref": "#/$defs/LintIssue"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "ok"
      ],
      "type": "object"
    },
    "DepRow": {
      "properties": {
        "locked": {
          "anyOf": [
            {
              "$ref": "#/$defs/LockedInfo"
            },
            {
              "type": "null"
            }
          ],
          "description": "Lockfile row, present only when `akua.lock` exists and\ncontains a matching entry."
        },
        "name": {
          "type": "string"
        },
        "source": {
          "description": "`\"oci\"` / `\"git\"` / `\"path\"` / `\"unknown\"`.",
          "type": "string"
        },
        "source_ref": {
          "description": "The actual ref recorded in `akua.toml`.",
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "source",
        "source_ref"
      ],
      "type": "object"
    },
    "DirDiff": {
      "description": "Structural diff between two directory trees. All paths are\nrelative to the respective root; sorted alphabetically for\ndeterministic output.",
      "properties": {
        "added": {
          "description": "Files present in the `after` root but not the `before` root.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "changed": {
          "description": "Files present in both but with differing sha256 content.",
          "items": {
            "$ref": "#/$defs/FileChange"
          },
          "type": "array"
        },
        "removed": {
          "description": "Files present in the `before` root but not the `after` root.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "skipped": {
          "description": "Entries that aren't regular files (symlinks, fifos, sockets…).\nSurfaced so the caller knows the diff isn't exhaustive, without\nthe diff itself trying to semantically compare those kinds.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "unchanged": {
          "description": "Files present in both with identical sha256 content.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "added",
        "removed",
        "changed"
      ],
      "type": "object"
    },
    "ExitCode": {
      "description": "The seven typed exit codes every akua verb may produce.\n\nAgents branch on these. Humans read them. The stability contract is\nthat meanings never change; new codes require a major version bump.\n\nSerialized as the stable kebab-case name (`\"success\"`, `\"user-error\"`,\n`\"policy-deny\"`, etc.) — same string [`ExitCode::name`] returns. The\nSDK maps from the numeric `child.exitCode` (0..=6) to this name.",
      "oneOf": [
        {
          "const": "success",
          "description": "`0` — operation completed as requested.",
          "type": "string"
        },
        {
          "const": "user-error",
          "description": "`1` — invalid inputs, bad flags, missing required arguments.\nSomething the caller got wrong.",
          "type": "string"
        },
        {
          "const": "system-error",
          "description": "`2` — unexpected failure (disk, network, bug). Something akua\ncouldn't recover from that isn't the caller's fault.",
          "type": "string"
        },
        {
          "const": "policy-deny",
          "description": "`3` — the policy engine rejected the operation.",
          "type": "string"
        },
        {
          "const": "rate-limited",
          "description": "`4` — registry / API rate limits. Retry with backoff.",
          "type": "string"
        },
        {
          "const": "needs-approval",
          "description": "`5` — the operation is allowed but requires human approval\nbefore it can proceed.",
          "type": "string"
        },
        {
          "const": "timeout",
          "description": "`6` — operation did not complete within `--timeout`.",
          "type": "string"
        }
      ]
    },
    "FileChange": {
      "properties": {
        "after": {
          "description": "`sha256:<hex>` of the `after` file's contents.",
          "type": "string"
        },
        "before": {
          "description": "`sha256:<hex>` of the `before` file's contents.",
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "before",
        "after"
      ],
      "type": "object"
    },
    "FmtFile": {
      "properties": {
        "changed": {
          "description": "True when the file's contents differ from the formatter's\noutput. Under `--check`, this flips the exit code to\n[`ExitCode::UserError`]; without `--check`, the file is\nrewritten in place.",
          "type": "boolean"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "changed"
      ],
      "type": "object"
    },
    "FmtOutput": {
      "properties": {
        "files": {
          "items": {
            "$ref": "#/$defs/FmtFile"
          },
          "type": "array"
        }
      },
      "required": [
        "files"
      ],
      "type": "object"
    },
    "InspectOutput": {
      "description": "Discriminated JSON shape. `kind: \"package\"|\"tarball\"` carries the\nvariant; consumers parse one body and branch.",
      "oneOf": [
        {
          "$ref": "#/$defs/PackageInspectBody",
          "properties": {
            "kind": {
              "const": "package",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "$ref": "#/$defs/TarballInspectBody",
          "properties": {
            "kind": {
              "const": "tarball",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        }
      ]
    },
    "Level": {
      "description": "Log severity. Almost always `Error`; `Warn` for recoverable issues.",
      "enum": [
        "error",
        "warn"
      ],
      "type": "string"
    },
    "LintIssue": {
      "description": "Structured issue reported by [`lint_kcl`]. Mirrors KCL's own\n`Error.messages[*]` shape, flattened one-row-per-message so\nconsumers don't need to walk a two-level tree.",
      "properties": {
        "code": {
          "description": "KCL error code (e.g. `\"E1001\"`). Empty string when KCL emits no\ncode — preserved verbatim.",
          "type": "string"
        },
        "column": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "file": {
          "type": [
            "string",
            "null"
          ]
        },
        "level": {
          "description": "`\"Error\"` or `\"Warning\"` as reported by KCL.",
          "type": "string"
        },
        "line": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "level",
        "code",
        "message"
      ],
      "type": "object"
    },
    "LintOutput": {
      "properties": {
        "issues": {
          "items": {
            "$ref": "#/$defs/LintIssue"
          },
          "type": "array"
        },
        "status": {
          "description": "`\"ok\"` when no issues reported; `\"fail\"` otherwise.",
          "type": "string"
        }
      },
      "required": [
        "status",
        "issues"
      ],
      "type": "object"
    },
    "LockedInfo": {
      "properties": {
        "digest": {
          "type": "string"
        },
        "replaced_by": {
          "description": "Local fork override active for this dep. When set, the dep's\ncanonical source is whatever the manifest declared, but build-\ntime resolution reads files from `replaced_by`.",
          "type": [
            "string",
            "null"
          ]
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "digest"
      ],
      "type": "object"
    },
    "OptionInfo": {
      "description": "A single `option()` call-site in a parsed Package, surfaced for\ninspection without executing the program. Mirrors kcl_lang's\n`OptionHelp` shape with idiomatic Rust optionals.",
      "properties": {
        "default": {
          "description": "Default value (literal form) when the option call includes one.",
          "type": [
            "string",
            "null"
          ]
        },
        "help": {
          "description": "`help=\"…\"` text attached to the option call, surfaced in docs\ntooling; absent when the authoring site didn't provide any.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "The option key (first argument to `option(\"…\")`).",
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "type": {
          "description": "The declared type of the binding receiving the option — e.g.\n`\"Input\"` for `input: Input = option(\"input\") or Input {}`.\nEmpty when the option is used without a type annotation.",
          "type": "string"
        }
      },
      "required": [
        "name",
        "required"
      ],
      "type": "object"
    },
    "PackageInfo": {
      "properties": {
        "edition": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "edition"
      ],
      "type": "object"
    },
    "PackageInspectBody": {
      "properties": {
        "options": {
          "items": {
            "$ref": "#/$defs/OptionInfo"
          },
          "type": "array"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "options"
      ],
      "type": "object"
    },
    "RenderSummary": {
      "description": "Verdict for a single render: where manifests went, how many, and a\nhash that makes \"did the rendered output change?\" a byte comparison.",
      "properties": {
        "files": {
          "description": "Relative filenames, in write order. Empty vec is serialized as\nomitted to keep the JSON shape tight.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "format": {
          "type": "string"
        },
        "hash": {
          "description": "`sha256:<hex>` of the concatenated `<filename>\\n<yaml>` blocks.\nFilename participates in the hash so two identical resources\nrouted to different filenames produce different hashes.",
          "type": "string"
        },
        "manifests": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "target": {
          "description": "Directory the manifests were written into (or would be, on\n`--dry-run`). Absolute or relative depending on the `out_root`\nthe caller passed.",
          "type": "string"
        }
      },
      "required": [
        "format",
        "target",
        "manifests",
        "hash",
        "files"
      ],
      "type": "object"
    },
    "StructuredError": {
      "description": "The canonical error shape. One struct; every verb reuses it.\n\n`code` is the stable, load-bearing identifier. `message` is the one-line\nsummary. The rest are optional pointers — a file path, a field name, a\nsuggestion, a docs URL.",
      "properties": {
        "code": {
          "description": "Stable, machine-readable identifier (SHOUTY_SNAKE_CASE).\nExample: `E_SCHEMA_INVALID`, `E_OCI_DIGEST_MISMATCH`.",
          "type": "string"
        },
        "docs": {
          "description": "URL to the error's documentation page. Convention:\n`https://akua.dev/errors/<CODE>`.",
          "type": [
            "string",
            "null"
          ]
        },
        "field": {
          "description": "Dotted field path inside `path` when the error is field-specific.\nExample: `spec.replicas`, `metadata.labels.team`.",
          "type": [
            "string",
            "null"
          ]
        },
        "level": {
          "$ref": "#/$defs/Level",
          "default": "error",
          "description": "Log level. Always `\"error\"` for hard failures; `\"warn\"` for\nrecoverable issues emitted alongside a success exit."
        },
        "line": {
          "description": "1-based line number in `path` when applicable.",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "message": {
          "description": "Human-readable one-line summary.",
          "type": "string"
        },
        "next_actions": {
          "description": "Machine-executable recovery steps. Agents can use these to fix\nthe error programmatically. Each entry is a complete command.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "path": {
          "description": "File path, OCI ref, or resource identifier the error refers to.",
          "type": [
            "string",
            "null"
          ]
        },
        "suggestion": {
          "description": "Actionable suggestion — a one-liner the caller can apply.\nAbsent when there's no generic fix.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "code",
        "message"
      ],
      "type": "object"
    },
    "Summary": {
      "properties": {
        "declared_deps": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "locked_packages": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "strict_signing": {
          "type": "boolean"
        }
      },
      "required": [
        "declared_deps",
        "locked_packages",
        "strict_signing"
      ],
      "type": "object"
    },
    "TarballInspectBody": {
      "properties": {
        "compressed_size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "file_count": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "layer_digest": {
          "type": "string"
        },
        "package_edition": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "package_name": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "package_version": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": "string"
        },
        "uncompressed_size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "vendored_deps": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "path",
        "layer_digest",
        "compressed_size_bytes",
        "uncompressed_size_bytes",
        "file_count",
        "vendored_deps"
      ],
      "type": "object"
    },
    "TreeOutput": {
      "description": "Output shape for `akua tree --json`.",
      "properties": {
        "dependencies": {
          "items": {
            "$ref": "#/$defs/DepRow"
          },
          "type": "array"
        },
        "package": {
          "$ref": "#/$defs/PackageInfo"
        }
      },
      "required": [
        "package",
        "dependencies"
      ],
      "type": "object"
    },
    "VerifyOutput": {
      "description": "Verify verdict JSON shape. Stable across releases.",
      "properties": {
        "status": {
          "description": "`\"ok\"` when everything checks out; `\"fail\"` otherwise. Derived\nfrom `violations.is_empty()`.",
          "type": "string"
        },
        "summary": {
          "$ref": "#/$defs/Summary"
        },
        "violations": {
          "description": "Structured violations. Empty when `status == \"ok\"`.",
          "items": {
            "$ref": "#/$defs/Violation"
          },
          "type": "array"
        }
      },
      "required": [
        "status",
        "summary",
        "violations"
      ],
      "type": "object"
    },
    "VersionOutput": {
      "description": "Version response shape.",
      "properties": {
        "version": {
          "description": "Semver version of the `akua` binary.",
          "type": "string"
        }
      },
      "required": [
        "version"
      ],
      "type": "object"
    },
    "Violation": {
      "oneOf": [
        {
          "description": "Dep declared in `akua.toml` but missing from `akua.lock`.",
          "properties": {
            "kind": {
              "const": "unlocked_dep",
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name"
          ],
          "type": "object"
        },
        {
          "description": "Package locked in `akua.lock` but not declared in `akua.toml`.",
          "properties": {
            "kind": {
              "const": "orphan_locked",
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name",
            "version"
          ],
          "type": "object"
        },
        {
          "description": "Package is locked without a signature while `strict_signing = true`.",
          "properties": {
            "kind": {
              "const": "missing_signature",
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name",
            "version"
          ],
          "type": "object"
        },
        {
          "description": "Path-dep on-disk content diverges from the digest `akua.lock`\npinned. Someone mutated the vendored chart without re-running\n`akua add` — either intentional (run add to refresh) or\naccidental (revert the edit).",
          "properties": {
            "actual": {
              "type": "string"
            },
            "expected": {
              "type": "string"
            },
            "kind": {
              "const": "path_digest_drift",
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name",
            "expected",
            "actual"
          ],
          "type": "object"
        },
        {
          "description": "Path-dep's declared target no longer exists on disk. Likely a\ndeleted `./vendor/<chart>` directory.",
          "properties": {
            "kind": {
              "const": "path_missing",
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name",
            "path"
          ],
          "type": "object"
        },
        {
          "description": "An OCI dep has no `.att` attestation sidecar at the registry,\nbut the workspace has a cosign public key configured (policy\nsays \"every dep must be attested\"). Publisher-actionable.",
          "properties": {
            "kind": {
              "const": "attestation_missing",
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "oci_ref": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name",
            "oci_ref"
          ],
          "type": "object"
        },
        {
          "description": "DSSE envelope failed cryptographic verification (bad\nsignature, wrong signer, cross-type substitution).\nAttacker-side signal.",
          "properties": {
            "detail": {
              "type": "string"
            },
            "kind": {
              "const": "attestation_invalid",
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "oci_ref": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name",
            "oci_ref",
            "detail"
          ],
          "type": "object"
        },
        {
          "description": "Attestation verified cryptographically but the subject\ndigest it claims to describe doesn't match the lockfile-pinned\ndigest for this dep. Attestation-for-a-different-artifact.",
          "properties": {
            "claimed": {
              "type": "string"
            },
            "expected": {
              "type": "string"
            },
            "kind": {
              "const": "attestation_subject_mismatch",
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name",
            "expected",
            "claimed"
          ],
          "type": "object"
        }
      ]
    },
    "WhoamiOutput": {
      "description": "Whoami response shape. Part of the stability contract — new fields\nmay be added (backward-compatible); existing field semantics never\nchange.",
      "properties": {
        "agent_context": {
